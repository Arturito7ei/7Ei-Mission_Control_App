# ──────────────────────────────────────────
# 7Ei Backend — Environment Variables
# ──────────────────────────────────────────

# ─ Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─ LLM APIs
ANTHROPIC_API_KEY=sk-ant-...        # required
OPENAI_API_KEY=sk-...               # optional: enables GPT-4o, GPT-4o-mini
GEMINI_API_KEY=AIza...              # optional: enables Gemini 2.0 Flash, 1.5 Pro

# ─ Database
DATABASE_URL=file:./dev.db          # local SQLite
DATABASE_AUTH_TOKEN=                # Turso auth token (production)

# ─ Vector Search (Pinecone)
PINECONE_API_KEY=                   # optional: enables semantic knowledge search
PINECONE_INDEX=7ei-knowledge        # index name
PINECONE_PROJECT_ID=                # from Pinecone dashboard
PINECONE_ENVIRONMENT=us-east-1-aws  # serverless region

# ─ Google (Drive + Gmail + Meet)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─ GitHub (skill sync)
GITHUB_TOKEN=

# ─ Jira
JIRA_DOMAIN=your-org                # your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT=O7MC

# ─ Redis (optional: enables distributed rate limiting)
REDIS_URL=redis://localhost:6379

# ─ Rate limits (defaults shown)
RATE_LIMIT_RPM=60
RATE_LIMIT_TOKENS_DAY=500000
RATE_LIMIT_COST_DAY=5.0
RATE_LIMIT_CONCURRENT=5

# ─ Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
PUBLIC_URL=https://api.7ei.ai       # used for Jira webhook URL generation
