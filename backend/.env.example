# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=

# Google (Knowledge Base + Gmail + Meet)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub (skill sync)
GITHUB_TOKEN=

# Jira (optional — can also set per-org via API)
JIRA_DOMAIN=your-org
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT=O7MC

# Rate limits (optional — defaults shown)
RATE_LIMIT_RPM=60
RATE_LIMIT_TOKENS_DAY=500000
RATE_LIMIT_COST_DAY=5.0
RATE_LIMIT_CONCURRENT=5

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
PUBLIC_URL=https://api.7ei.ai
